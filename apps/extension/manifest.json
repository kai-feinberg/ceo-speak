{
  "manifest_version": 3,
  "name": "Text Intelligence",
  "description": "Grammarly-style suggestions for focused text boxes.",
  "version": "0.1.0",
  "action": {
    "default_title": "Text Intelligence"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:5173/*", "http://localhost:5173/*"],
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:5173/*", "http://localhost:5173/*"],
      "js": ["src/content/main.tsx"],
      "run_at": "document_idle"
    }
  ]
}
